{
  "name": "agent-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "check": "tsc --noEmit",
    "db:init:local": "wrangler d1 execute agent-hub-db --local --file=schema.sql",
    "db:init:staging": "wrangler d1 execute agent-hub-db --env staging --file=schema.sql",
    "db:init:production": "wrangler d1 execute agent-hub-db --env production --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
